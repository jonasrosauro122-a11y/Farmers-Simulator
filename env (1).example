# Supabase connection (client-side; anon keys are safe for frontend use when RLS is enabled).
# Find these in Supabase: Project Settings -> API.
# Copy this file to ".env" and fill in your own project values, then restart the dev server.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

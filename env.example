# Supabase connection (client-side; these are safe to expose in a frontend build).
# Find them in your Supabase project: Settings -> API.
# Copy this file to ".env" and fill in your own values, then restart the dev server.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
